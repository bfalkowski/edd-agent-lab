# Model provider (required for live agent generation and optional LLM judge checks)
OPENAI_API_KEY=

# Agent generation mode: mock | live | auto
# - mock: deterministic template graph (CI default)
# - live: OpenAI-backed structured discovery + chat/brief responses
# - auto: live when OPENAI_API_KEY is set, otherwise mock
AGENT_GENERATION_MODE=auto

# Optional model override for live agent generation
# AGENT_MODEL=gpt-4o-mini

# Optional: EDD platform API — set these to publish runs over HTTP (see docs/05-platform-integration.md)
# EDD_CLIENT_MODE=http
# EDD_API_BASE_URL=http://127.0.0.1:8000
# EDD_TENANT_ID=tenant-a
# EDD_EVAL_SPEC_ID=
# EDD_API_KEY=                      # Bearer JWT; required when platform auth is enabled (local_e2e default)
# EDD_TOKEN_FILE=/tmp/edd-api.token # alternative to EDD_API_KEY (written by platform local_e2e.sh)
# EDD_CONSOLE_BASE_URL=http://localhost:8501

# Optional: MCP server URL (Milestone 8+). Empty uses local MCP tool shims.
# EDD_MCP_SERVER_URL=

# Optional: Langfuse (later milestone)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
